# URL of the OpenTaoAPI instance to read snapshots from.
OPENTAO_API_URL=http://localhost:8000

# Path to OpenTaoAPI's SQLite. Optional; only the backtester touches it.
# Leave blank when API and trader run on different machines.
OPENTAO_DB_PATH=

# Trader's own SQLite for paper/live trading state.
DATABASE_PATH=data/opentaotrader.db

# Bittensor network used by the live-trading CLI (signing only).
BITTENSOR_NETWORK=finney
# SUBTENSOR_ENDPOINT=ws://your-own-node:9944

# Run the paper-trading scheduler. Default off so a fresh install doesn't
# immediately advance anyone's bot.
PAPER_TRADING_ENABLED=false

# Colon-separated paths to extra strategy files / directories.
# OPENTAO_EXTERNAL_STRATEGIES=/opt/my_strategies

API_HOST=0.0.0.0
API_PORT=8009
